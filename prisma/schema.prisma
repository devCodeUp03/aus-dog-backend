generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model AdminUser {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  createdAt    DateTime @default(now())
}

model Order {
  id             String        @id @default(cuid())
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  address        String
  country        String        @default("Australia")
  deliveryFee    Float
  email          String
  firstName      String
  lastName       String
  orderNumber    Int           @unique @default(autoincrement())
  paymentMethod  PaymentMethod
  paypalOrderId  String?       @unique
  phone          String
  postcode       String
  state          String
  stripeIntentId String?       @unique
  subtotal       Float
  suburb         String
  total          Float
  userId         String?
  status         OrderStatus   @default(PENDING)
  items          OrderItem[]

  paid            Boolean  @default(false)
  refunded        Boolean  @default(false)
  refundId        String?
  refundReason    String?
  stripeSessionId String?
  paypalCaptureId String?
}

model OrderItem {
  id          String @id @default(cuid())
  orderId     String
  productName String
  color       String
  variant     String
  quantity    Int
  price       Float
  size        String
  order       Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)
}

enum OrderStatus {
  PENDING
  SHIPPING
  COMPLETED
}

enum PaymentMethod {
  STRIPE
  PAYPAL
}
